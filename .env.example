# Tofi Environment Variables
# 复制此文件为 .env 并填入真实值
TOFI_JWT_SECRET='secret'

# AI Services
OPENAI_API_KEY=sk-your_openai_api_key_here

# Tofi 官方 OpenAI Token (用于 tofi/ai_response action)
TOFI_OPENAI_API_KEY=sk-tofi_official_openai_key_here

# Messaging & Notifications
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR/WEBHOOK

# Telegram (用户自己的 Bot,在 workflow 中使用)
# TELEGRAM_BOT_TOKEN=your_personal_bot_token
# TELEGRAM_CHAT_ID=your_chat_id

# Telegram (Tofi 官方 Bot,可选)
# 如果设置此值,用户在 workflow 中可以不提供 bot_token
TOFI_TELEGRAM_BOT_TOKEN=tofi_official_bot_token_here

# Email (SMTP)
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your_email@gmail.com
# SMTP_PASSWORD=your_smtp_password

# GitHub
# GITHUB_TOKEN=ghp_your_github_token_here

# Add your custom secrets below
# MY_CUSTOM_API_KEY=your_key_here
